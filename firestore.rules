rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Usuários ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // ─── Métricas ─────────────────────────────────────────────────────────────
    // Leitura pública (autenticados E anônimos) para suportar relatórios compartilhados
    // Escrita apenas para usuários autenticados não-anônimos
    match /metrics/{metricId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ─── Estratégias de anúncio ───────────────────────────────────────────────
    match /ad_strategies/{strategyId} {
      allow read, write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == request.resource.data.userId;
    }

    // ─── Links de compartilhamento ────────────────────────────────────────────
    // Leitura pública (autenticados E anônimos) para permitir acesso ao relatório
    // sem que o visitante precise fazer login
    match /share_links/{linkId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == request.resource.data.userId;
    }

    // ─── Benchmarks de IA ─────────────────────────────────────────────────────
    match /ai_benchmarks/{benchmarkId} {
      allow read, write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == request.resource.data.userId;
    }

    // ─── Detalhes mensais ─────────────────────────────────────────────────────
    // Leitura pública para carregar métricas de agendamentos/vendas no relatório
    match /monthlyDetails/{detailId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ─── monthly_details (coleção alternativa) ────────────────────────────────
    match /monthly_details/{detailId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == request.resource.data.userId;
    }

    // ─── Campanhas sincronizadas ──────────────────────────────────────────────
    match /campaigns/{campaignDocId} {
      allow read, write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == request.resource.data.userId;
    }

    // ─── Seleções do usuário ──────────────────────────────────────────────────
    match /user_selections/{userId} {
      allow read, write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == userId;
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.auth.uid == request.resource.data.userId;
    }

    // ─── Benchmark Values (projeções) ─────────────────────────────────────────
    match /benchmarkValues/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ─── Analysis Planner ─────────────────────────────────────────────────────
    match /analysisPlanner/{docId} {
      allow read, write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ─── Histórico de Análise ─────────────────────────────────────────────────
    // Leitura permitida para autenticados (incl. anônimos) para relatórios compartilhados
    match /analysisHistory/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ─── Aurea Settings ───────────────────────────────────────────────────────
    match /aureaSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ─── Regra geral para outras coleções (usuários autenticados não-anônimos) ─
    match /{document=**} {
      allow read, write: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }
  }
}
